{
  "expo": {
    "name": "meals",
    "slug": "meals",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/android/res/mipmap-xxxhdpi/ic_launcher_foreground.png",
    "scheme": "meals",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3C6530",
        "foregroundImage": "./assets/android/res/mipmap-xxxhdpi/ic_launcher_foreground.png",
        "backgroundImage": "./assets/android/res/mipmap-xxxhdpi/ic_launcher_background.png",
        "monochromeImage": "./assets/android/res/mipmap-xxxhdpi/ic_launcher_monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.holycannoli.meals"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/android/res/mipmap-xxxhdpi/ic_launcher_foreground.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/android/res/mipmap-xxhdpi/ic_launcher.png",
          "imageWidth": 420,
          "resizeMode": "contain",
          "backgroundColor": "#489e2e",
          "dark": {
            "backgroundColor": "#377823"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": true,
          "barStyle": "light",
          "visibility": " leanback"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
